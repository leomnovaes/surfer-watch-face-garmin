<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <setting propertyKey="@Properties.ClockFont" title="@Strings.ClockFontTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.FontSaira</listEntry>
            <listEntry value="1">@Strings.FontRajdhani</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.WindSpeedUnit" title="@Strings.WindSpeedUnitTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.WindSpeedAuto</listEntry>
            <listEntry value="1">@Strings.WindSpeedKph</listEntry>
            <listEntry value="2">@Strings.WindSpeedKnots</listEntry>
            <listEntry value="3">@Strings.WindSpeedMph</listEntry>
            <listEntry value="4">@Strings.WindSpeedMs</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.WeatherSource" title="@Strings.WeatherSourceTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.WeatherSourceGarmin</listEntry>
            <listEntry value="1">@Strings.WeatherSourceOWM</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.OWMApiKey" title="@Strings.OWMApiKeyTitle">
        <settingConfig type="alphaNumeric"/>
    </setting>

    <setting propertyKey="@Properties.StormGlassApiKey" title="@Strings.StormGlassApiKeyTitle">
        <settingConfig type="alphaNumeric"/>
    </setting>

    <setting propertyKey="@Properties.HomeLat" title="@Strings.HomeLatTitle">
        <settingConfig type="alphaNumeric"/>
    </setting>

    <setting propertyKey="@Properties.HomeLng" title="@Strings.HomeLngTitle">
        <settingConfig type="alphaNumeric"/>
    </setting>

</settings>
